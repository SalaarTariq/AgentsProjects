# PostCreationAgent Environment Variables
# Copy this file to .env and fill in your API keys

# Google Gemini API Key (free tier) - https://aistudio.google.com/apikey
# Used as the LLM brain for the agent (prompt engineering, decisions, captions)
GOOGLE_API_KEY=

# LLM Model (default: gemini-2.0-flash, free and fast)
LLM_MODEL=gemini-2.0-flash

# HuggingFace API Token (free tier) - https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Stability AI API Key (free tier) - https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# Together AI API Key (free tier) - https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Instagram Graph API (requires Facebook Business account)
# Follow setup guide: https://developers.facebook.com/docs/instagram-api/getting-started
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
